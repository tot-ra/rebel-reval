{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "location.schema.json",
  "title": "Reval Rebel location content",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "type",
    "id",
    "name",
    "district",
    "confidence",
    "canon_status",
    "approval",
    "description",
    "gameplay_space",
    "pressure_tags",
    "phase_states",
    "source_notes"
  ],
  "properties": {
    "type": {
      "const": "location"
    },
    "id": {
      "$ref": "common.schema.json#/$defs/content_id"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "district": {
      "type": "string",
      "enum": [
        "Lower Town",
        "Toompea",
        "Harbor",
        "Outside Reval",
        "Interior"
      ]
    },
    "confidence": {
      "$ref": "common.schema.json#/$defs/confidence_label"
    },
    "canon_status": {
      "$ref": "common.schema.json#/$defs/canon_status"
    },
    "approval": {
      "$ref": "common.schema.json#/$defs/review_record"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "gameplay_space": {
      "type": "boolean"
    },
    "scene_path": {
      "type": "string",
      "pattern": "^res://.+\\.tscn$"
    },
    "spawn_ids": {
      "type": "array",
      "items": {
        "$ref": "common.schema.json#/$defs/local_id"
      }
    },
    "connected_location_ids": {
      "type": "array",
      "items": {
        "$ref": "common.schema.json#/$defs/content_id"
      }
    },
    "occupant_ids": {
      "type": "array",
      "items": {
        "$ref": "common.schema.json#/$defs/content_id"
      }
    },
    "pressure_tags": {
      "type": "array",
      "items": {
        "$ref": "common.schema.json#/$defs/pressure"
      }
    },
    "phase_states": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "description"
        ],
        "properties": {
          "id": {
            "$ref": "common.schema.json#/$defs/local_id"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "conditions": {
            "type": "array",
            "items": {
              "$ref": "common.schema.json#/$defs/condition"
            }
          }
        }
      }
    },
    "source_notes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "common.schema.json#/$defs/source_note"
      }
    }
  }
}
