{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "character.schema.json",
  "title": "Reval Rebel character content",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "type",
    "id",
    "name",
    "role",
    "confidence",
    "canon_status",
    "approval",
    "pronunciation",
    "brief",
    "relationships",
    "voice",
    "outcomes",
    "source_notes"
  ],
  "properties": {
    "type": {
      "const": "character"
    },
    "id": {
      "$ref": "common.schema.json#/$defs/content_id"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "aliases": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "role": {
      "type": "string",
      "minLength": 1
    },
    "age": {
      "type": "integer",
      "minimum": 0
    },
    "is_player": {
      "type": "boolean"
    },
    "confidence": {
      "$ref": "common.schema.json#/$defs/confidence_label"
    },
    "canon_status": {
      "$ref": "common.schema.json#/$defs/canon_status"
    },
    "approval": {
      "$ref": "common.schema.json#/$defs/review_record"
    },
    "pronunciation": {
      "type": "string",
      "minLength": 1
    },
    "brief": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "want",
        "fear",
        "contradiction",
        "secret_or_withheld_fact"
      ],
      "properties": {
        "want": {
          "type": "string",
          "minLength": 1
        },
        "fear": {
          "type": "string",
          "minLength": 1
        },
        "contradiction": {
          "type": "string",
          "minLength": 1
        },
        "secret_or_withheld_fact": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "target_id",
          "summary"
        ],
        "properties": {
          "target_id": {
            "$ref": "common.schema.json#/$defs/content_id"
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "valence": {
            "type": "string",
            "enum": [
              "ally",
              "family",
              "dependent",
              "adversary",
              "patron",
              "temptation",
              "unknown"
            ]
          }
        }
      }
    },
    "voice": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "diction"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "diction": {
          "type": "string",
          "minLength": 1
        },
        "languages": {
          "type": "array",
          "items": {
            "$ref": "common.schema.json#/$defs/language"
          },
          "minItems": 1
        }
      }
    },
    "outcomes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "summary"
        ],
        "properties": {
          "id": {
            "$ref": "common.schema.json#/$defs/local_id"
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "conditions": {
            "type": "array",
            "items": {
              "$ref": "common.schema.json#/$defs/condition"
            }
          }
        }
      }
    },
    "source_notes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "common.schema.json#/$defs/source_note"
      }
    }
  }
}
