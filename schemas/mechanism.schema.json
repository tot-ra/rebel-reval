{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mechanism.schema.json",
  "title": "Reval Rebel mechanism content",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "type",
    "id",
    "title",
    "commission_id",
    "object_item_id",
    "location_id",
    "confidence",
    "canon_status",
    "approval",
    "responses",
    "default_response",
    "source_notes"
  ],
  "properties": {
    "type": {
      "const": "mechanism"
    },
    "id": {
      "$ref": "common.schema.json#/$defs/content_id"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "commission_id": {
      "$ref": "common.schema.json#/$defs/content_id"
    },
    "object_item_id": {
      "$ref": "common.schema.json#/$defs/content_id"
    },
    "location_id": {
      "$ref": "common.schema.json#/$defs/content_id"
    },
    "confidence": {
      "$ref": "common.schema.json#/$defs/confidence_label"
    },
    "canon_status": {
      "$ref": "common.schema.json#/$defs/canon_status"
    },
    "approval": {
      "$ref": "common.schema.json#/$defs/review_record"
    },
    "responses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "common.schema.json#/$defs/mechanism_response"
      }
    },
    "default_response": {
      "$ref": "common.schema.json#/$defs/mechanism_response"
    },
    "source_notes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "common.schema.json#/$defs/source_note"
      }
    }
  }
}
