# Spawn offsets must clear trigger half-size plus player capsule (r=16,h=32)
# so arrivals do not immediately re-fire the green transition volumes.
# District adjacency follows medieval Reval (Tallinn Old Town):
# west = Vana Turg into the civic centre, north = Vene/Pikk into the north
# quarter, east = Viru Gate road into its exterior foreland, and the south-west
# interior lane continues directly into the southern quarter. Karja Gate remains
# an exterior city-wall gate rather than forcing travel outside the fortifications.
transition vana_turg_boundary 0 51 2 4 destination_spawn=from_reval_east spawn=vana_turg_boundary spawn_offset_px=96,0 to=reval_center highlight_area=true transition_visual=ground
transition vene_district_boundary 24 0 3 2 destination_spawn=from_reval_east spawn=vene_district_boundary spawn_offset_px=0,96 to=reval_monastery highlight_area=true transition_visual=ground
transition viru_road_boundary 145 51 4 3 destination_spawn=from_reval_east spawn=viru_road_boundary spawn_offset_px=-128,0 to=viru_gate_foreland highlight_area=true transition_visual=ground
transition to_reval_south 59 126 14 2 to=reval_south destination_spawn=from_reval_east spawn=from_reval_south spawn_offset_px=0,-128 highlight_area=true transition_visual=ground
transition street_start_spawn 83 54 2 2 spawn=street_start
patrol viru_watch 110,53|80,53|65,53|65,75|65,88|65,116
fade fade.viru_street 17 46 76 22
camera 0 0 152 128
sign sign.viru_road "viru gate and eastern road" 135 46 east
sign sign.town_centre "to town centre" 3 49 west
sign sign.south_quarter "to knights district" 64 122 south
sign sign.karja_gate "karja gate" 71 116 south
