building blackheads_corner house 73 28 8 8 style=house.merchant.north
building guild_storehouse house 73 58 10 6 style=house.merchant.north
building west_lane_house_north house 36 10 6 10 style=house.merchant.south
building west_lane_house_mid house 36 46 6 10 style=house.merchant.south
building west_lane_house_south house 36 82 6 8 style=house.merchant.south
building pikk_merchant_south_west house 81 70 8 8 style=house.merchant.north
building pikk_merchant_south_east house 109 70 8 8 style=house.merchant.north
building pikk_merchant_mid_west house 81 34 8 10 style=house.merchant.north
building pikk_merchant_mid_east house 109 28 8 10 style=house.merchant.north
building lai_merchant_south house 135 70 10 8 style=house.merchant.north
building lai_merchant_mid house 138 28 12 10 style=house.merchant.north
building lai_corner_tenement house 151 46 14 10 style=house.merchant.north
building lai_east_row_mid house 172 16 10 10 style=house.merchant.south
building lai_east_row_south house 172 82 10 8 style=house.merchant.north
building workshop_row_west house 120 10 12 6 style=house.service
building workshop_row_mid house 122 46 12 6 style=house.service
building netmakers_loft house 120 76 10 6 style=house.service
building shoemakers_guild house 151 34 10 8 style=house.merchant.north
building market_house_east house 185 66 12 9 style=house.merchant.south
building convent_almonry house 13 66 14 8 style=house.service
landmark monastery_west_gate_arch gate_arch 0 28 8 12 wall_color=8f8c80ff top_px=240 passage_axis=x door_material=wood
prop convent_well well 47 44 rect=2,2
prop garden_bench table 29 48 rect=2,1
prop guild_stall stall 62 40 rect=2,2
prop merchant_stall stall 96 48 rect=3,2
prop street_cart cart 101 84 rect=2,2
prop service_barrels barrels 161 54 rect=2,2
prop convent.ash tree 58 48 style=tree.ash
prop convent.elm tree 8 72 style=tree.elm
prop convent.linden tree 58 69 style=tree.linden
prop lai.maple tree 162 70 style=tree.maple
spawn spawn.inspection 101 52 rect=2,2
anchor inspection_spawn 101 52 rect=2,2
anchor monastery_close 26 52 rect=2,2
anchor st_olaf_frontage 99 74 rect=2,2
anchor guild_frontage 68 49 rect=2,2
anchor pikk_street_spine 101 56 rect=2,2
anchor from_reval_north 104 6 rect=2,2
# Keep local-x aligned with market_civic to_reval_north (Pikk corridor, cell 39)
# so stacked district alignment stays cycle-consistent.
anchor from_reval_center 37 104 rect=2,2
anchor from_reval_east 139 104 rect=2,2
anchor from_reval_toompea 8 34 rect=2,2
transition to_reval_north 98 0 12 2 to=reval_north destination_spawn=from_monastery spawn=from_reval_north spawn_offset_px=0,96 highlight_area=true transition_visual=ground
transition to_reval_center 33 108 12 4 to=reval_center destination_spawn=to_reval_north spawn=from_reval_center spawn_offset_px=0,-128 highlight_area=true transition_visual=ground
transition to_reval_east 134 108 11 4 to=reval_east destination_spawn=vene_district_boundary spawn=from_reval_east spawn_offset_px=0,-128 highlight_area=true transition_visual=ground
transition to_reval_toompea 0 28 3 12 to=reval_toompea destination_spawn=from_reval_north spawn=from_reval_toompea spawn_offset_px=96,0 highlight_area=true transition_visual=ground view_landmark_id=monastery_west_gate_arch
sign sign.merchant "to merchant district" 106 6 north
sign sign.center "to town square" 36 103 south
sign sign.vene "to workers' district" 136 103 south
sign sign.toompea "pikk jalg to toompea" 8 32 west
sign sign.convent "st michael's convent" 49 47 west
sign sign.olaf "st olaf's" 99 80 north
patrol monastery_watch 101,6|101,30|101,56|101,88|39,104|135,88|159,104|135,56|68,54|26,54|8,34
fade fade.convent 10 10 55 58
fade fade.olaf 75 50 65 42
camera 0 0 208 112
surroundings north town east town south town west town
