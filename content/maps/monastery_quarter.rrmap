# Monastery District between the civic market and the northern merchant ward.
# St. Olaf's precinct, St. Michael's Cistercian convent, guild frontages, and
# the Pikk/Lai approaches form a broad lower half of the former north quarter.
#
# P4-023e: great_guild_front, blackheads_corner, and brotherhood_wing keep stable
# IDs but render as generic merchant masses. Later Great Guild Hall (1407-10) and
# Brotherhood/Blackheads institutional frontages are excluded (HISTORICAL_AUDIT
# cross-map exclusion 2; monastery landmark row).
#
# Surface policy (docs/HISTORICAL_AUDIT.md monastery_quarter + MAP_AUTHORING):
# packed-earth base, garden/grass precincts and margins, small stone closes only,
# cobble limited to primary street spines. Secondary lanes use mud/earth wear.
# Map-wide cobblestone fill is forbidden (HISTORICAL_AUDIT cross-map exclusion 1).
rrmap 1
map monastery_quarter loc.lower_town.monastery_quarter 208 112 dirt scope=prototype active=false palette=clean_painted seed=2721 cell_size=32
source "scenes/reval_monastery/reval_monastery.tscn"
source "scenes/revel-map.jpg"
source "scenes/reval_north/st_olafs_church.md"
source "docs/HISTORICAL_AUDIT.md"
source "docs/MAP_AUTHORING.md"
style house.merchant.south door_side=south roof_color=3d3329ff roof_material=shingle wall_color=706352ff wall_material=plank wall_height=120
style house.merchant.north door_side=north roof_color=3b332bff roof_material=shingle wall_color=756654ff wall_material=plaster wall_height=120
style house.church door_side=south roof_color=2e241cff roof_material=tile wall_color=807a70ff wall_material=limestone wall_height=192
style house.convent door_side=east ridge_axis=x roof_color=42261fff roof_material=tile wall_color=8c867aff wall_material=limestone wall_height=128
style house.service door_side=north roof_color=6b5c40ff roof_material=thatch wall_color=5a4f45ff wall_material=log wall_height=88
style wall.precinct wall_height=112 wall_color=8d897fff
style wall.city wall_height=192 wall_color=949185ff
style wall.tower wall_height=240 wall_color=8c8a80ff
style plant.nettle
style plant.yarrow
style plant.dandelion
style plant.chamomile
style plant.caraway
style plant.st_johns_wort
style plant.mugwort
style plant.plantain
style tree.ash
style tree.elm
style tree.linden
style tree.maple
terrain district.base dirt 0 0 208 112 order=1
terrain convent.garden grass 5 8 58 68 order=2
terrain wall.margin.west grass 3 8 8 96 order=3
terrain wall.margin.east grass 190 8 15 96 order=3
terrain south.seam.grass grass 30 98 110 14 order=3
terrain lai.rear.grass grass 148 60 22 28 order=3
# Medicinal beds and disturbed-ground plants around the convent and wall margins.
terrain convent.nettle grass 45 59 6 4 style=plant.nettle order=3
terrain convent.yarrow grass 52 59 6 4 style=plant.yarrow order=3
terrain convent.chamomile grass 45 64 6 4 style=plant.chamomile order=3
terrain convent.caraway grass 52 64 6 4 style=plant.caraway order=3
terrain wall.dandelion grass 3 80 8 6 style=plant.dandelion order=3
terrain wall.st_johns_wort grass 3 88 8 6 style=plant.st_johns_wort order=3
terrain wall.mugwort grass 190 78 15 6 style=plant.mugwort order=3
terrain wall.plantain grass 190 86 15 6 style=plant.plantain order=3
terrain convent.close stone 18 22 24 22 order=4
terrain olaf.close stone 80 56 30 22 order=5
terrain guild.threshold stone 44 28 22 8 order=6
terrain service.yard dirt 146 12 52 50 order=7
terrain workshop.yards mud 118 10 28 24 order=8
terrain east.yards mud 168 40 28 36 order=8
terrain pikk.frontage.mud mud 96 20 14 70 order=8
stroke pikk_spine cobblestone 101,0|101,24|101,52|101,80|101,110 thickness=4 order=9
stroke lai_lane cobblestone 135,0|135,28|135,58|135,88|135,110 thickness=3 order=10
stroke vene_lane cobblestone 153,110|153,94|164,94|179,94|179,110 thickness=3 order=11
stroke civic_lane cobblestone 39,110|39,98|86,98|94,98|101,98 thickness=3 order=12
stroke guild_lane mud 23,54|49,54|49,72|75,72|75,88|101,88 thickness=3 order=13
stroke convent_lane mud 0,34|23,34|23,54|49,54 thickness=3 order=14
# Tallinn's medieval wall circuit continues along the exposed west and east
# sides. The open north/south district seams remain streets rather than walls.
building monastery_city_wall_west_north wall 0 0 3 20 style=wall.city
building monastery_wall_tower_northwest wall 0 0 8 8 style=wall.tower tower=true door_side=east
# The western gate cut is retained for inter-district travel, but later paired
# gate-tower silhouettes are deliberately suppressed in the 1343 snapshot.
building monastery_west_gate_north_tower wall 0 20 8 8 style=wall.tower tower=false
building monastery_west_gate_south_tower wall 0 40 8 8 style=wall.tower tower=false
building monastery_west_gate_north_jamb wall 0 27 8 2 style=wall.city tower=false
building monastery_west_gate_south_jamb wall 0 39 8 2 style=wall.city tower=false
building monastery_city_wall_west_south wall 0 48 3 64 style=wall.city
building monastery_wall_tower_west_mid wall 0 72 8 8 style=wall.tower tower=true door_side=east
building monastery_wall_tower_southwest wall 0 104 8 8 style=wall.tower tower=false
building monastery_city_wall_east wall 205 0 3 112 style=wall.city
building monastery_wall_tower_northeast wall 200 0 8 8 style=wall.tower tower=false
building monastery_wall_tower_east_mid wall 200 52 8 8 style=wall.tower tower=false
building monastery_wall_tower_southeast wall 200 104 8 8 style=wall.tower tower=false
building st_michaels_convent house 16 16 22 14 style=house.convent
building convent_chapel house 16 36 14 10 style=house.church
building convent_service_wing house 44 16 10 22 style=house.service
building convent_precinct_wall_north wall 10 10 52 2 style=wall.precinct
building convent_precinct_wall_west wall 10 10 2 48 style=wall.precinct
building convent_precinct_wall_south wall 10 56 36 2 style=wall.precinct
building st_olaf_silhouette house 83 58 22 14 style=house.church
building olaf_precinct_west house 68 76 10 8 style=house.merchant.south
building olaf_precinct_east house 117 70 12 8 style=house.merchant.north
building great_guild_front house 44 22 20 8 style=house.merchant.north
