building east_merchant_row house 78 48 12 7 style=house.merchant.north
building vana_turg_east_frontage house 92 36 10 8 style=house.merchant.west
building eastern_backstreet_north house 92 12 10 8 style=house.merchant.backstreet
building eastern_backstreet_mid house 92 54 10 8 style=house.merchant.backstreet
building eastern_backstreet_south house 92 81 10 8 style=house.wooden.backstreet
