# Unified Central District around Raekoja plats. The market occupies the civic
# square itself rather than a separate enclosure: Pikk continues north-east to
# the Monastery District, Vana Turg/Viru east into the Workers' District, and
# Niguliste west toward Toompea. Karja Gate itself sits on the eastern map's
# southern wall; do not wire a centre edge to that outside-the-walls exit.
# Town Hall closes the square's southern edge while Holy Spirit chapel, its
# almshouse, guild and merchant frontages tighten the northern approaches.
rrmap 1
map market_civic_quarter loc.lower_town.market_civic_quarter 104 96 dirt scope=prototype active=false palette=clean_painted seed=1343 cell_size=32
source "scenes/reval_center/reval_center.tscn"
source "scenes/revel-map.jpg"
source "scenes/reval_center/market_civic_quarter/market.md"
source "scenes/reval_center/market_civic_quarter/town_hall_square.md"
source "scenes/reval_center/market_civic_quarter/town_hall.md"
source "scenes/reval_center/market_civic_quarter/church_of_the_holy_spirit.md"
source "docs/HISTORICAL_AUDIT.md"
# 1343 Reval used local limestone for civic, church, and wealthy merchant work.
# Most surrounding houses remain plastered, plank-clad, or log-built under
# shingle. The Town Hall predates its 1402-1404 tower/current form; Holy Spirit
# is represented as the earlier chapel-almshouse complex without its later tower
# or seventeenth-century clock; the post-1422 Raeapteek identity is avoided.
style house.town_hall door_side=north ridge_axis=x primitive=town_hall_1343 wall_height=152 wall_color=918b80ff wall_material=limestone roof_color=4a2a20ff roof_material=tile
style house.church door_side=south ridge_axis=x primitive=holy_spirit_chapel_1343 wall_height=176 wall_color=9e998cff wall_material=limestone roof_color=42261fff roof_material=tile
style house.hospital door_side=south ridge_axis=x wall_height=112 wall_color=807a70ff wall_material=limestone roof_color=3d3329ff roof_material=shingle
style house.guild door_side=east ridge_axis=x wall_height=136 wall_color=7a7061ff wall_material=limestone roof_color=47291fff roof_material=tile
style house.merchant.gabled door_side=south ridge_axis=z primitive=stepped_gable_merchant wall_height=144 wall_color=756b5cff wall_material=limestone roof_color=4a2a20ff roof_material=tile
style house.merchant.south door_side=south ridge_axis=x wall_height=120 wall_color=756b5cff wall_material=plaster roof_color=3d3329ff roof_material=shingle
style house.merchant.north door_side=north ridge_axis=x wall_height=120 wall_color=706352ff wall_material=plank roof_color=383029ff roof_material=shingle
style house.merchant.east door_side=east ridge_axis=z wall_height=112 wall_color=695e4fff wall_material=plaster roof_color=3b332bff roof_material=shingle
style house.merchant.west door_side=west ridge_axis=z wall_height=112 wall_color=665c4dff wall_material=plank roof_color=38332eff roof_material=shingle
style house.artisan door_side=north ridge_axis=x wall_height=96 wall_color=63594aff wall_material=log roof_color=6b5c40ff roof_material=thatch
style house.merchant.backstreet door_side=south ridge_axis=x wall_height=104 wall_color=6f6658ff wall_material=plaster roof_color=3a312aff roof_material=shingle
style house.wooden.backstreet door_side=west ridge_axis=z wall_height=88 wall_color=5d5447ff wall_material=log roof_color=6b5c40ff roof_material=thatch
terrain square.cobble cobblestone 18 18 58 51 order=1
terrain town_hall_forecourt stone 24 63 34 6 order=2
terrain holy_spirit_close stone 36 15 28 6 order=3
terrain market_wear mud 22 32 42 19 order=4
terrain guild_forecourt stone 14 26 6 12 order=5
stroke street.pikk cobblestone 54,21|42,21|38,21|38,0 thickness=3 order=6
stroke street.pikk_continuation cobblestone 38,0|38,21|72,21|72,0 thickness=3 order=7
stroke street.vana_turg cobblestone 58,39|76,39|76,45|103,45 thickness=4 order=8
stroke street.apothecary_lane cobblestone 66,18|66,30|76,30|88,30|88,45 thickness=3 order=9
stroke street.east_market_lane cobblestone 72,57|88,57|88,78|103,78 thickness=3 order=10
stroke street.southern_town_hall cobblestone 14,83|24,83|38,83|54,83|68,83 thickness=3 order=11
stroke street.kuninga_branch cobblestone 68,83|68,90|82,90|96,90 thickness=3 order=12
stroke street.karja cobblestone 38,12|38,24|38,36 thickness=4 order=13
stroke street.niguliste cobblestone 0,44|12,44|12,41|18,41 thickness=3 order=14
stroke street.rataskaev cobblestone 0,59|12,59|12,53|18,53 thickness=3 order=15
stroke street.king cobblestone 12,95|12,83|20,83|20,68 thickness=3 order=16
building town_hall_mass house 26 69 26 7 style=house.town_hall
