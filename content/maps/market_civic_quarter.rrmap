building rataskaev_corner_house house 0 63 10 8 style=house.merchant.east
building king_street_house house 14 69 10 6 style=house.artisan
building karja_corner_house house 22 69 3 6 style=house.merchant.west
prop civic_well well 52 47 rect=2,2
prop notice_cart cart 20 41 rect=2,2
prop guild_stall stall 21 24 rect=3,2
prop fish_stall stall 27 32 rect=3,2
prop cloth_stall stall 35 32 rect=3,2
prop grain_stall stall 43 32 rect=3,2
prop pottery_stall stall 51 32 rect=3,2
prop weigh_table_prop table 31 44 rect=3,2
prop market_cart cart 45 47 rect=2,2
prop market_barrels barrels 59 47 rect=2,2
spawn spawn.inspection 46 53 rect=2,2
anchor inspection_spawn 46 53 rect=2,2
anchor town_hall_edge 40 66 rect=2,2
anchor pikk_street_spine 38 15 rect=2,2
anchor vana_turg_neck 82 45 rect=2,2
anchor karja_lane 38 27 rect=2,2
anchor holy_spirit_frontage 46 18 rect=2,2
anchor market_cross 46 44 rect=2,2
anchor weigh_table 32 47 rect=2,2
# East = Vana Turg into the Viru/eastern district. North = Pikk into the north
# quarter (St. Olaf / Great Guild). Pikk passes west of Holy Spirit rather than
# through its mass. Do not wire any centre edge to Karja Gate's outside-the-walls
# exit on the eastern map.
transition to_reval_east 102 42 2 5 to=reval_east destination_spawn=vana_turg_boundary spawn=from_reval_east spawn_offset_px=-96,0
transition to_reval_north 36 0 10 2 to=reval_monastery destination_spawn=from_reval_center spawn=to_reval_north spawn_offset_px=0,96
transition to_reval_toompea 0 41 3 5 to=reval_toompea destination_spawn=from_reval_center spawn=to_reval_toompea spawn_offset_px=96,0 highlight_area=true transition_visual=ground
transition to_reval_south 6 95 12 1 to=reval_south destination_spawn=from_reval_center spawn=to_reval_south spawn_offset_px=0,-96 highlight_area=true transition_visual=ground
transition to_guild_hall 16 27 2 2 to=st_olafs_guild_hall destination_spawn=from_reval_center spawn=to_guild_hall spawn_offset_px=96,0
sign sign.viru "to viru street" 96 42 east
sign sign.karja "karja street" 36 24 south
sign sign.pikk "to pikk street" 36 6 north
sign sign.niguliste "to st nicholas" 6 47 west
sign sign.toompea "to toompea" 4 42 west
sign sign.south "to rataskaev" 12 92 south
sign sign.town_hall "town hall" 40 65 south
sign sign.holy_spirit "holy spirit chapel" 46 21 north
patrol civic_watch 38,3|38,21|54,21|66,30|84,45|76,45|76,63|76,81|68,83|24,83|24,66|40,66|26,51|20,42|82,45
fade fade.town_hall 22 63 36 18
fade fade.holy_spirit 34 0 44 20
camera 0 0 104 96
surroundings north town east town south town west town
