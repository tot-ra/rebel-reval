prop rope_props barrels 70 12 rect=2,2
prop street_cart cart 50 40 rect=2,2
prop dock_barrels barrels 58 6 rect=2,2
prop guild_stall stall 20 48 rect=2,2
prop merchant_stall_a stall 44 36 rect=3,2
prop merchant_stall_b stall 58 36 rect=3,2
prop harbor_cart cart 48 4 rect=2,2
spawn spawn.inspection 50 46 rect=2,2
anchor inspection_spawn 50 46 rect=2,2
anchor pikk_street_spine 50 36 rect=2,2
anchor guild_frontage 24 51 rect=2,2
anchor harbor_approach 50 6 rect=2,2
anchor from_reval_east 78 68 rect=2,2
anchor from_reval_center 44 68 rect=2,2
anchor from_reval_harbor 50 4 rect=2,2
transition to_reval_harbor 46 0 10 3 to=reval_harbor destination_spawn=from_reval_north spawn=to_reval_harbor spawn_offset_px=0,96 highlight_area=true transition_visual=ground
# South-edge arrivals need offsets past trigger half-height plus the player
# capsule (r=16,h=32). 14x4 / 10x6 volumes reject -96 and bounce center/east.
transition to_reval_center 38 68 14 4 to=reval_center destination_spawn=to_reval_north spawn=from_reval_center spawn_offset_px=0,-128 highlight_area=true transition_visual=ground
transition to_reval_east 72 66 10 6 to=reval_east destination_spawn=vene_district_boundary spawn=from_reval_east spawn_offset_px=0,-160 highlight_area=true transition_visual=ground
sign sign.harbour "to harbour" 52 4 north
sign sign.vene "to vene street" 80 66 south
sign sign.center "to town square" 40 66 south
sign sign.guild "great guild" 24 50 west
sign sign.pikk "pikk street" 52 12 north
sign sign.lai "lai street" 74 40 east
# Keep waypoints on walkable Pikk/Lai/guild cobbles; buildings block 50,66 and 50,8.
patrol merchant_watch 51,47|52,47|53,47|54,47|55,47|55,48|55,49
exclude blocked.church 40 54 18 10
fade fade.olaf 32 52 28 16
camera 0 0 104 72
surroundings north water east town south town west town
