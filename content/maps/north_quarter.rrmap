building lai_corner_tenement house 88 50 14 10 style=house.north.h136.22
building lai_east_row_north house 90 30 12 10 style=house.north.h112.21
building lai_east_row_mid house 92 40 10 10 style=house.north.h120.20
building lai_east_row_south house 94 62 8 8 style=house.north.h112.19
building workshop_row_west house 64 38 12 6 style=house.workshop.mid
building workshop_row_mid house 66 26 12 6 style=house.workshop.low
building workshop_row_east house 68 14 12 6 style=house.workshop.mid
