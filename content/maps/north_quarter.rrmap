# Northern merchant quarter between St. Olaf's and the Great Coast Gate.
# Pikk Street runs south-north from the civic square and eastern Vene approach
# through dense Hanseatic merchant rows to the harbour quay. Great Guild and
# Brotherhood frontages face the lane west; maritime workshops cluster north.
rrmap 1
map north_quarter loc.lower_town.north_quarter 104 72 cobblestone scope=prototype active=false palette=clean_painted seed=2718 cell_size=32
source "scenes/reval_north/reval_north.tscn"
source "scenes/revel-map.jpg"
source "scenes/reval_north/pikk_street.md"
source "scenes/reval_north/st_olafs_church.md"
source "scenes/reval_north/great_guild_hall.md"
source "scenes/reval_north/brotherhood_of_blackheads_house.md"
source "scenes/reval_north/goldsmiths_row.md"
source "scenes/reval_north/shipwrights_yard.md"
source "scenes/reval_north/ropemakers_guild.md"
# 1343 materials: guild hall and St. Olaf's in limestone with tile; merchant
# rows plastered or plank under shingle; workshop rows and sheds log-built
# under thatch and shingle (see docs/HISTORICAL_AUDIT.md).
style house.south.h112.16 door_side=south roof_color=3d3329ff roof_material=shingle wall_color=6b5e4fff wall_material=log wall_height=112
style house.south.h120.18 door_side=south roof_color=3d3329ff roof_material=shingle wall_color=706352ff wall_material=plank wall_height=120
style house.north.h112.19 door_side=north roof_color=3d3329ff roof_material=shingle wall_color=6b5e4fff wall_material=plaster wall_height=112
style house.north.h112.21 door_side=north roof_color=3b332bff roof_material=shingle wall_color=695e4fff wall_material=plank wall_height=112
style house.north.h120.20 door_side=north roof_color=423629ff roof_material=shingle wall_color=756654ff wall_material=plank wall_height=120
style house.north.h136.22 door_side=north ridge_axis=z roof_color=42241cff roof_material=shingle wall_color=857a6bff wall_material=plank wall_height=136
style house.east.h112.14 door_side=east roof_color=383029ff roof_material=shingle wall_color=665c4dff wall_material=log wall_height=112
style house.west.h120.13 door_side=west roof_color=423629ff roof_material=shingle wall_color=756654ff wall_material=plaster wall_height=120
style house.guild.hall door_side=south roof_color=4a2a20ff roof_material=tile wall_color=6b5e4fff wall_material=limestone wall_height=136
style house.church.silhouette door_side=none roof_color=2e241cff roof_material=tile wall_color=807a70ff wall_material=limestone wall_height=192
style house.workshop.low door_side=north roof_color=6b5c40ff roof_material=thatch wall_color=5a4f45ff wall_material=log wall_height=72
style house.workshop.mid door_side=north roof_color=383029ff roof_material=shingle wall_color=63594aff wall_material=log wall_height=88
style house.merchant.gabled door_side=south ridge_axis=z primitive=stepped_gable_merchant wall_height=144 wall_color=756b5cff wall_material=limestone roof_color=4a2a20ff roof_material=tile
style house.merchant.plank door_side=north ridge_axis=x wall_height=120 wall_color=706352ff wall_material=plank roof_color=383029ff roof_material=shingle
style house.warehouse door_side=south roof_color=352820ff roof_material=shingle wall_color=5a4f45ff wall_material=plank wall_height=64
terrain quarter.base cobblestone 0 0 104 72 order=1
terrain guild.plaza stone 6 42 28 14 order=2
terrain lane.dirt dirt 30 20 34 28 order=3
terrain yard.mud mud 64 2 36 14 order=4
terrain north.grass grass 0 2 14 18 order=5
terrain dock.forecourt mud 42 2 34 8 order=6
stroke pikk_spine cobblestone 50,68|50,58|50,48|50,38|50,28|50,18|50,8|50,2 thickness=4 order=7
stroke lai_lane cobblestone 72,64|72,54|72,44|72,34|72,24|72,14|72,6 thickness=3 order=8
stroke guild_lane cobblestone 10,42|18,42|18,50|26,50|26,56|34,56 thickness=3 order=9
stroke vene_lane cobblestone 76,68|76,62|80,62|84,62 thickness=3 order=10
stroke center_lane cobblestone 42,68|42,64|36,64|30,64 thickness=3 order=11
stroke harbor_lane cobblestone 46,2|50,2|54,2 thickness=3 order=12
building south_entry_house_west house 30 64 10 6 style=house.south.h112.16
