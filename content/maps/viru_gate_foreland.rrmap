style grass.tall
style grass.dry
style bush.dense
style bush.scrub
style reed.shore
style tree.mixed
style tree.spruce
style tree.oak
style tree.birch
style tree.pine
style tree.alder
style tree.maple
style tree.linden
style tree.birch.large
style tree.oak.small
