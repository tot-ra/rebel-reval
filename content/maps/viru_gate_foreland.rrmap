# Viru Gate road foreland east of the Workers' District. The gate and main road
# are plausible mid-fourteenth-century works; the sparse roadside compounds,
# ditches and plot geometry remain conservative reconstruction.
rrmap 1
map viru_gate_foreland loc.reval.viru_gate_foreland 112 80 meadow scope=prototype active=false palette=clean_painted seed=1343 cell_size=32
source "scenes/reval_east/viru_gate_foreland/viru_gate_foreland.tscn"
source "docs/HISTORICAL_AUDIT.md"
style house.croft wall_height=62 wall_color=675b4dff wall_material=log roof_color=756548ff roof_material=thatch door_side=south
style house.shed wall_height=50 wall_color=5e5143ff wall_material=plank roof_color=493b2cff roof_material=shingle door_side=south
style house.inn wall_height=68 wall_color=706457ff wall_material=log roof_color=51402eff roof_material=shingle door_side=south
